# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Node / Next.js ──────────────────────────────────────────────────────────
# no leading slash → matches site/node_modules, site/.next, etc.
node_modules/
.next/
out/
.vercel
site/build/
site/coverage/
site/playwright-report/
site/test-results/

# Next.js generated
next-env.d.ts
*.tsbuildinfo

# Yarn / pnpm
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-debug.log*

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
venv/
.venv/
*.egg-info/
.pytest_cache/
.py-packages/

# ── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment ─────────────────────────────────────────────────────────────
.env*

# ── Data / generated output ─────────────────────────────────────────────────
store_pdl.json
output/

# ── Misc ────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
.ralphex/
.playwright-cache/
.npm-cache/
dist/
desktop/.vite/desktop/dist/
desktop/dist-electron/
desktop/dist-renderer/
.py-packages/
.cache_ggshield
__pycache__/
.claude/