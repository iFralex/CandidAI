    "build:dir": "vite build && tsc -p tsconfig.electron.json && electron-builder --dir",
    "run:app": "dist/mac-arm64/desktop.app/Contents/MacOS/desktop",
    "logs": "open \"$HOME/Library/Logs/desktop\" 2>/dev/null || echo 'Log directory not found. Run the packaged app first.'",
